# RapidAPI key — get one free at https://rapidapi.com (subscribe to Sky-Scrapper)
RAPIDAPI_KEY=your_key_here

# Neon PostgreSQL connection string (from Neon dashboard → Connection Details)
DATABASE_URL=postgres://user:pass@host/dbname?sslmode=require

# One-time setup secret — protects GET /api/db/setup
SETUP_SECRET=any-random-string

# Restrict CORS to your deployed frontend URL in production
# Leave as * for local dev
ALLOWED_ORIGIN=https://your-app.vercel.app
