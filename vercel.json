{
  "functions": {
    "api/flights.js": {
      "memory": 128,
      "maxDuration": 15
    },
    "api/schengen/trips.js": {
      "memory": 128,
      "maxDuration": 10
    },
    "api/notes/index.js": {
      "memory": 128,
      "maxDuration": 10
    },
    "api/db/setup.js": {
      "memory": 128,
      "maxDuration": 15
    }
  },
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/$1"
    }
  ],
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "s-maxage=300, stale-while-revalidate=60"
        }
      ]
    }
  ]
}
